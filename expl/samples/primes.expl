int main()
{
decl
    int temp,num,j,flag;
enddecl
begin
    num=2;
    while ( num <= 100 ) do
        j = 2;
	flag = 1;
	while ((j * j) < num) do
		if ((num % j) == 0) then
			flag = 0;
			break;
		endif;
		j = j + 1;
	endwhile;
	if (flag == 1) then
		temp = exposcall ( "Write" , -2, num );
	endif;
        num = num + 1;
    endwhile;
    return 0;
end
}
